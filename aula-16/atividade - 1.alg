algoritmo "atividade-1"
// Função : Implemente um algoritmo que realiaze a soma dos números de
// -10 a 10(usando laço de repetição)
// Data : 28/04/2026
// Seção de Declarações 
var
   soma, contador: inteiro
   
inicio
      soma <- 0
      
      para contador de -10 ate 10 faca
           soma <- soma + contador
      fimpara
      
      escreval(soma)
      
fimalgoritmo
