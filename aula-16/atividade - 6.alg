algoritmo "atividade-6"
// Função : Elabore um algoritmo que calcule e
// escreva a tabuada de um número X qualquer, digitado pelo usuário.
// Data : 28/04/2026
var
   cal, val: inteiro
inicio
   escreval("Digite um numero: ")
   leia(val)

   para cal de 1 ate 10 faca
        escreval(val, " x ", cal, " = ", val * cal)
   fimpara
fimalgoritmo
