algoritmo "atividade-10"
// Função :Desenvolva um algoritmo que calcule a
// soma dos números inteiros de 1 a 50.
// Data : 23/04/2026
var
   num,total: inteiro
inicio
   total <- 0
   
   para num de 1 ate 50 faca
      total <- total + num
   fimpara

   escreval("A soma de 1 até 50 é: ", total)

fimalgoritmo